+/*
+ * Camera additions for Lenovo CD-18781Y
+ * 2026-04-28: Initial OV5693 enablement (single front-facing camera).
+ *
+ * Hardware (from Lenovo downstream apq8053-camera-sensor-dragon.dtsi):
+ *   Sensor:    OmniVision OV5693, 5MP, CSI-2 4-lane
+ *   I2C:       cci_i2c0 (CCI bus 0), slave 0x36 (OV5693 default)
+ *   MCLK:      TLMM 26, GCC_CAMSS_MCLK0_CLK @ 24 MHz
+ *   Reset:     TLMM 40, active low
+ *   Powerdown: TLMM 39, active low
+ *   Supplies:  avdd=pm8953_l17 (2.85V), dovdd=pm8953_l6 (1.8V), dvdd=pm8953_l2 (1.2V)
+ *   Lanes:     CSIPHY0, 4 data lanes (vendor lane mask 0x1F)
+ */
+
+&camss {
+	status = "okay";
+	vdda-supply = <&pm8953_s3>;
+
+	ports {
+		port@0 {
+			reg = <0>;
+			csiphy0_ep: endpoint {
+				clock-lanes = <7>;
+				data-lanes = <0 1>;
+				remote-endpoint = <&ov5693_ep>;
+			};
+		};
+	};
+};
+
+&cci {
+	pinctrl-names = "default";
+	pinctrl-0 = <&cci0_default>, <&camss_mclk0_default>;
+	status = "okay";
+};
+
+&cci_i2c0 {
+	ov5693: camera-sensor@36 {
+		compatible = "ovti,ov5693";
+		reg = <0x36>;
+
+		clocks = <&gcc GCC_CAMSS_MCLK0_CLK>;
+		clock-names = "xvclk";
+		assigned-clocks = <&gcc GCC_CAMSS_MCLK0_CLK>;
+		assigned-clock-rates = <19200000>;
+
+		reset-gpios = <&tlmm 40 GPIO_ACTIVE_LOW>;
+		powerdown-gpios = <&tlmm 39 GPIO_ACTIVE_LOW>;
+
+		avdd-supply = <&pm8953_l17>;
+		dovdd-supply = <&pm8953_l6>;
+		dvdd-supply = <&pm8953_l2>;
+
+		rotation = <0>;
+		orientation = <0>;
+
+		port {
+			ov5693_ep: endpoint {
+				data-lanes = <0 1>;
+				link-frequencies = /bits/ 64 <419200000>;
+				remote-endpoint = <&csiphy0_ep>;
+			};
+		};
+	};
 };
